{
  "name": "kaartje",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@kaartje/api",
    "dev:web": "npm run dev --workspace=@kaartje/web",
    "dev:mobile": "npm run dev --workspace=@kaartje/mobile",
    "lint": "oxlint",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "oxfmt": "latest",
    "oxlint": "latest",
    "expo": "~55.0.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2"
  },
  "version": "1.0.0"
}
